<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2366"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_titre_fin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vous avez perdu"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Carte score -->
    <LinearLayout
        android:id="@+id/card_score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_bg"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintWidth_max="500dp"
        app:layout_constraintTop_toBottomOf="@id/tv_titre_fin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Votre score"
            android:textColor="#A0A5D0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_score_final"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFAA00"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_coins_gagnes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pièces gagnées : +0"
            android:textColor="#A0A5D0"
            android:textSize="14sp" />

        <!-- Thème utilisé -->
        <TextView
            android:id="@+id/tv_theme_used"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Véhicule : ATHLÈTE"
            android:textColor="#A0A5D0"
            android:textSize="13sp"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Boutons -->
    <Button
        android:id="@+id/btn_accueil"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:text="⌂ Accueil"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:backgroundTint="#323B8A"
        app:layout_constraintWidth_max="500dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_rejouer"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:text="↻ Rejouer"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:backgroundTint="#FFAA00"
        app:layout_constraintWidth_max="500dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_accueil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Classement par thème -->
    <LinearLayout
        android:id="@+id/card_leaderboard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintWidth_max="500dp"
        app:layout_constraintTop_toBottomOf="@id/card_score"
        app:layout_constraintBottom_toTopOf="@+id/btn_rejouer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_titre_classement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌍 Classement mondial"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:indeterminateTint="#FFAA00" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fadeScrollbars="false">

            <LinearLayout
                android:id="@+id/layout_lignes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>