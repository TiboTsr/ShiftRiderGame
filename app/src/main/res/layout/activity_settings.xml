<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2366"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paramètres ⚙️"
            android:textColor="#FFAA00"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio"
            android:textColor="#A0A5D0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Switch
            android:id="@+id/switch_musique"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Musique de fond"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/rounded_bg"/>

        <Switch
            android:id="@+id/switch_effets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Effets sonores (SFX)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="14dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/rounded_bg"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jeu &amp; Affichage"
            android:textColor="#A0A5D0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Switch
            android:id="@+id/switch_vibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vibrations"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/rounded_bg"/>

        <Switch
            android:id="@+id/switch_fps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode 60 FPS (Fluide)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="14dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/rounded_bg"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btn_reset_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Réinitialiser ma progression"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_retour_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retour à l'accueil"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>