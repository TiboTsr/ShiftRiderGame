<?xml version="1.0" encoding="utf-8"?>
<!--
    Fond de ligne mis en évidence pour le joueur actuel dans le classement.
    Même forme que bg_row mais avec une bordure et couleur dorée.
    À placer dans : app/src/main/res/drawable/bg_row_highlight.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2A2200" />
    <stroke
        android:width="1.5dp"
        android:color="#FFAA00" />
    <corners android:radius="12dp" />
</shape>