<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JeuBateau">

        <!--
            SCREEN_ORIENTATION_LOCKED : verrouille l'orientation courante au démarrage.
            Combiné à PORTRAIT dans le code Kotlin, ça garantit portrait strict sur tous
            les appareils et versions Android, même si l'utilisateur force la rotation
            dans les paramètres système.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GameActivity"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".GameOverActivity"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".GarageActivity"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".RulesActivity"
            android:exported="false"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".LeaderboardActivity"
            android:exported="false"
            android:screenOrientation="locked"
            tools:ignore="LockedOrientationActivity" />

    </application>
</manifest>